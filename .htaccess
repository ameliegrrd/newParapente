RewriteEngine On

# Redirect legacy PHP homepage URL
RewriteRule ^index\.php$ https://parapentemeribel.net/ [L,R=301,NC]
RewriteRule ^index\.php/prestations-par-saison-et-tarifs/?$ https://parapentemeribel.net/services.html [L,R=301,NC]

# Force canonical host + HTTPS
RewriteCond %{HTTP_HOST} ^www\.parapentemeribel\.net$ [NC,OR]
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://parapentemeribel.net%{REQUEST_URI} [L,R=301]

# Normalize home URL
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ https://parapentemeribel.net/ [L,R=301]
